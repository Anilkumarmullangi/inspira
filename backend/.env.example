# Example environment variables for Inspira backend
# Copy this to backend/.env and fill real values (do NOT commit .env)

PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/inspira
JWT_SECRET=replace_with_a_real_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional
#NODE_ENV=development
