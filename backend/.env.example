# Example environment variables for Inspira backend
# Copy this to backend/.env and fill real values (do NOT commit .env)

PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/inspira

# Replace with a strong secret before deploying (store locally, do NOT commit)
JWT_SECRET=replace_with_a_real_secret

# Cloudinary credentials (replace with your account values)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Optional
# NODE_ENV=development
